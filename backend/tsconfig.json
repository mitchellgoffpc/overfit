{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "types": ["node"],
    "paths": {
      "@underfit/types": ["../../packages/types/src"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "references": [{ "path": "../packages/types" }]
}
